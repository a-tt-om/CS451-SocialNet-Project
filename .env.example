# ============================================
# SocialNet — Environment Variables
# ============================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# App
APP_PORT=8888

# MySQL
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=socialnet
MYSQL_USER=socialnet_user
MYSQL_PASSWORD=socialnet_pass

# PHP (DB connection)
DB_HOST=mysql
DB_NAME=socialnet
DB_USER=socialnet_user
DB_PASS=socialnet_pass
